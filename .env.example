# Server configuration
PORT=3000
HOST=127.0.0.1

# Session configuration
# Generate a secure random string for production
SESSION_SECRET=change-this-to-a-secure-random-secret-key-123456

# Application login password
# When logging into the web dashboard, use this password
APP_PASSWORD=admin123

# Gemini API configuration
# OPTION A: Google AI Studio API Key (Easiest - get one free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# OPTION B: Vertex AI / Google Cloud
# To use, authenticate in your shell using: gcloud auth application-default login
# GCP_PROJECT=your_gcp_project_id_here
# GCP_LOCATION=us-central1
